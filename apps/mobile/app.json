{
  "expo": {
    "name": "watermelon_prototype",
    "slug": "watermelon_prototype",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "com.watermelonprototype",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o aplicativo acesse a câmera para escanear o QR Code de conexão local."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.watermelonprototype.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E7365",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.watermelonprototype.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
