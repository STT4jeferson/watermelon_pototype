# Geral
NODE_ENV=development
APP_ENV=local

# IMPORTANTE: IP da máquina na rede LAN para teste mobile (evite localhost se testar no celular físico)
LAN_IP=192.168.0.x

# MySQL da aplicação (Domínio)
MYSQL_DATABASE=watermelon_db
MYSQL_USER=watermelon_user
MYSQL_PASSWORD=watermelon_password
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# Postgres do Keycloak
KEYCLOAK_DB=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_password

# Keycloak
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:24.0.1
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=watermelon-local
KEYCLOAK_PUBLIC_URL=http://${LAN_IP}:8080
KEYCLOAK_ISSUER=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}
KEYCLOAK_MOBILE_CLIENT_ID=watermelon-mobile

# Backend
BACKEND_PORT=3333
DATABASE_URL=mysql://watermelon_user:watermelon_password@localhost:3306/watermelon_db
OIDC_ISSUER=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}
OIDC_JWKS_URI=${KEYCLOAK_PUBLIC_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs
OIDC_AUDIENCE=watermelon-backend